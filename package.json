{
	"name": "clash-armies",
	"version": "0.9.2",
	"private": true,
	"type": "module",
	"scripts": {
		"start:before": "docker compose up -d",
		"start": "pnpm run start:before && vite dev",
		"start:network": "pnpm run start:before && vite dev --host",
		"start:https": "DEV_HTTPS=1 pnpm run start:network",
		"production": "vite preview",
		"build": "vite build",
		"build:dev-image": "docker build -t clash-armies:devel .",
		"test:before": "docker compose --env-file=.env.test --file=compose.test.yaml down -v && docker compose --env-file=.env.test --file=compose.test.yaml up -d",
		"test:coverage": "pnpm run test:before && vitest run --coverage",
		"test:ui": "pnpm run test:before && vitest --ui --coverage.enabled=true",
		"test": "pnpm run test:before && vitest run",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json src"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"packageManager": "pnpm@11.0.3",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/eslint": "9.6.1",
		"@types/cookie-signature": "1.1.2",
		"@types/node": "24.11.0",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"@vitest/coverage-v8": "^4.1.8",
		"@vitest/ui": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"@vitejs/plugin-basic-ssl": "2.3.0",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.4",
		"@ninjalib/sql": "^0.5.1",
		"@ninjalib/util": "0.5.4",
		"@tiptap/core": "^3.26.0",
		"@tiptap/extension-bold": "^3.26.0",
		"@tiptap/extension-character-count": "^3.26.0",
		"@tiptap/extension-document": "^3.26.0",
		"@tiptap/extension-heading": "^3.26.0",
		"@tiptap/extension-horizontal-rule": "^3.26.0",
		"@tiptap/extension-italic": "^3.26.0",
		"@tiptap/extension-link": "^3.26.0",
		"@tiptap/extension-list": "^3.26.0",
		"@tiptap/extension-list-keymap": "^3.26.0",
		"@tiptap/extension-paragraph": "^3.26.0",
		"@tiptap/extension-placeholder": "^3.26.0",
		"@tiptap/extension-strike": "^3.26.0",
		"@tiptap/extension-text": "^3.26.0",
		"@tiptap/extension-text-align": "^3.26.0",
		"@tiptap/extensions": "^3.26.0",
		"@tiptap/html": "^3.26.0",
		"@tiptap/pm": "^3.26.0",
		"@tiptap/starter-kit": "^3.26.0",
		"zeed-dom": "0.18.0",
		"arctic": "1.5.0",
		"cron": "4.4.0",
		"date-fns": "3.6.0",
		"json5": "^2.2.3",
		"lucia": "3.1.1",
		"uuid": "^11.1.0",
		"cookie-signature": "1.2.2",
		"zod": "3.22.3"
	}
}
